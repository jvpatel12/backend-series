<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen">

  <div class="nav mb-10">

       <% users.forEach(function(user){ %>
        <div class="bg-white w-80 p-5 rounded-2xl shadow-lg text-center">
    
    <!-- User Image -->
    <img src="<%=user.image%>"  
         alt="User Image" 
         class="w-full h-full rounded-full mx-auto border-4 border-blue-300 shadow-md">
    
    <!-- User Info -->
    <h2 class="mt-3 text-xl font-bold text-gray-700"><%=user.name%></h2>
    <p class="text-gray-500"><%=user.email%></p>
    
    <!-- Action Links -->
    <div class="flex justify-center gap-4 mt-4">
      <a href="/update/<%=user._id%>" 
         class="px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 transition">Edit</a>
      <a href="/delete/<%=user._id%>" 
         class="px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600 transition">Delete</a>
    </div>
    </div>
         <% }) %>
  </div>

</body>
</html>