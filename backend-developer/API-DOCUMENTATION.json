{
  "apiVersion": "1.0.0",
  "title": "Bank Application API Documentation",
  "baseUrl": "http://localhost:5000/api",
  "description": "Complete API documentation for Bank Application with all endpoints and examples",
  "author": "Your Name",
  "lastUpdated": "2026-04-01",
  "apis": {
    "authentication": {
      "category": "Authentication",
      "description": "User authentication endpoints",
      "endpoints": [
        {
          "id": 1,
          "name": "Register User",
          "method": "POST",
          "endpoint": "/auth/register",
          "fullUrl": "http://localhost:5000/api/auth/register",
          "protected": false,
          "description": "Register a new user account",
          "requestHeaders": {
            "Content-Type": "application/json"
          },
          "requestBody": {
            "email": "john@example.com",
            "name": "John Doe",
            "password": "password123"
          },
          "responseSuccess": {
            "statusCode": 201,
            "body": {
              "user": {
                "_id": "65f8c1a2b3d4e5f6g7h8i9j0",
                "email": "john@example.com",
                "name": "John Doe"
              },
              "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI2NWY4YzFhMmIzZDRlNWY2ZzdoOGk5ajAiLCJpYXQiOjE3MTAwMDAwMDAsImV4cCI6MTcxMDI1ODAwMH0.abc123xyz",
              "message": "user create succuessfully"
            }
          },
          "responseError": {
            "statusCode": 400,
            "body": {
              "message": "user already exists with email"
            }
          }
        },
        {
          "id": 2,
          "name": "Login User",
          "method": "POST",
          "endpoint": "/auth/login",
          "fullUrl": "http://localhost:5000/api/auth/login",
          "protected": false,
          "description": "Login with email and password",
          "requestHeaders": {
            "Content-Type": "application/json"
          },
          "requestBody": {
            "email": "john@example.com",
            "password": "password123"
          },
          "responseSuccess": {
            "statusCode": 201,
            "body": {
              "user": {
                "_id": "65f8c1a2b3d4e5f6g7h8i9j0",
                "email": "john@example.com",
                "name": "John Doe"
              },
              "message": "user fetch the sucessfully",
              "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI2NWY4YzFhMmIzZDRlNWY2ZzdoOGk5ajAiLCJpYXQiOjE3MTAwMDAwMDAsImV4cCI6MTcxMDI1ODAwMH0.abc123xyz"
            }
          },
          "responseErrorInvalidEmail": {
            "statusCode": 401,
            "body": {
              "message": "email is not find write correct email"
            }
          },
          "responseErrorInvalidPassword": {
            "statusCode": 401,
            "body": {
              "message": "password is in correct add right password"
            }
          }
        },
        {
          "id": 3,
          "name": "Get User Profile",
          "method": "GET",
          "endpoint": "/auth/user",
          "fullUrl": "http://localhost:5000/api/auth/user",
          "protected": true,
          "description": "Get authenticated user profile information",
          "requestHeaders": {
            "Authorization": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "Content-Type": "application/json"
          },
          "requestBody": "No body required",
          "responseSuccess": {
            "statusCode": 200,
            "body": {
              "user": {
                "_id": "65f8c1a2b3d4e5f6g7h8i9j0",
                "email": "john@example.com",
                "name": "John Doe",
                "createdAt": "2025-03-20T10:30:00.000Z",
                "updatedAt": "2025-03-20T10:30:00.000Z"
              },
              "message": "User fetched successfully"
            }
          },
          "responseErrorInvalidToken": {
            "statusCode": 401,
            "body": {
              "message": "Unauthorized access token is invalid"
            }
          },
          "responseErrorMissingToken": {
            "statusCode": 401,
            "body": {
              "message": "Unauthorized access token is missing"
            }
          }
        }
      ]
    },
    "accounts": {
      "category": "Account Management",
      "description": "User account management endpoints",
      "endpoints": [
        {
          "id": 4,
          "name": "Create Account",
          "method": "POST",
          "endpoint": "/account/create",
          "fullUrl": "http://localhost:5000/api/account/create",
          "protected": true,
          "description": "Create a new bank account for authenticated user",
          "requestHeaders": {
            "Authorization": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "Content-Type": "application/json"
          },
          "requestBody": "No body required",
          "responseSuccess": {
            "statusCode": 201,
            "body": {
              "account": {
                "_id": "65f8c2b3b3d4e5f6g7h8i9j1",
                "user": "65f8c1a2b3d4e5f6g7h8i9j0",
                "status": "ACTIVE",
                "currency": "INR",
                "createdAt": "2025-03-20T10:35:00.000Z",
                "updatedAt": "2025-03-20T10:35:00.000Z"
              }
            }
          },
          "responseErrorMissingToken": {
            "statusCode": 401,
            "body": {
              "message": "Unauthorized access token is missing"
            }
          }
        },
        {
          "id": 5,
          "name": "Get User Account",
          "method": "GET",
          "endpoint": "/account/user",
          "fullUrl": "http://localhost:5000/api/account/user",
          "protected": true,
          "description": "Get bank account details for authenticated user",
          "requestHeaders": {
            "Authorization": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "Content-Type": "application/json"
          },
          "requestBody": "No body required",
          "responseSuccess": {
            "statusCode": 200,
            "body": {
              "account": {
                "_id": "65f8c2b3b3d4e5f6g7h8i9j1",
                "user": {
                  "_id": "65f8c1a2b3d4e5f6g7h8i9j0",
                  "email": "john@example.com",
                  "name": "John Doe"
                },
                "status": "ACTIVE",
                "currency": "INR",
                "createdAt": "2025-03-20T10:35:00.000Z",
                "updatedAt": "2025-03-20T10:35:00.000Z"
              },
              "message": "Account fetched successfully"
            }
          },
          "responseErrorAccountNotFound": {
            "statusCode": 404,
            "body": {
              "message": "Account not found for this user"
            }
          },
          "responseErrorInvalidToken": {
            "statusCode": 401,
            "body": {
              "message": "Unauthorized access token is invalid"
            }
          }
        }
      ]
    }
  },
  "testCredentials": [
