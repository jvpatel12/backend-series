  "authenticationMechanisms": {
    "description": "How to authenticate requests",
    "method1": "Bearer Token in Authorization Header",
    "example1": "Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
    "method2": "Token in Cookies",
    "example2": "Cookie: token=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
  },
  "curlExamples": {
    "registerUser": "curl -X POST http://localhost:5000/api/auth/register -H 'Content-Type: application/json' -d '{\"email\":\"john@example.com\",\"name\":\"John Doe\",\"password\":\"password123\"}'",
    "loginUser": "curl -X POST http://localhost:5000/api/auth/login -H 'Content-Type: application/json' -d '{\"email\":\"john@example.com\",\"password\":\"password123\"}'",
    "getUserProfile": "curl -X GET http://localhost:5000/api/auth/user -H 'Authorization: Bearer YOUR_TOKEN_HERE'",
    "createAccount": "curl -X POST http://localhost:5000/api/account/create -H 'Authorization: Bearer YOUR_TOKEN_HERE'",
    "getUserAccount": "curl -X GET http://localhost:5000/api/account/user -H 'Authorization: Bearer YOUR_TOKEN_HERE'"
  },
  "errorCodes": {
    "401": {
      "description": "Unauthorized",
      "causes": [
        "Invalid or missing authentication token",
        "Token has expired",
        "Invalid credentials"
      ]
    },
    "403": {
      "description": "Forbidden",
      "causes": [
        "User does not have permission to access resource",
        "User is not a system user"
      ]
    },
    "404": {
      "description": "Not Found",
      "causes": [
        "User not found",
        "Account not found",
        "Resource does not exist"
      ]
    },
    "500": {
      "description": "Internal Server Error",
      "causes": [
        "Server error occurred",
        "Database error",
        "Unexpected error"
      ]
    }
  },
  "environment": {
    "development": "http://localhost:5000",
    "production": "https://api.bankapp.com"
  },
  "notes": [
    "All protected endpoints require valid JWT token",
    "Tokens are valid for 3-5 days depending on endpoint",
    "Token can be sent in Authorization header as Bearer token or in cookies",
    "Email must be unique for registration",
    "Password must be at least 6 characters long"
  ]
}
