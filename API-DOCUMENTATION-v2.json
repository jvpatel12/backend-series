    "transactions": {
      "category": "Transactions",
      "description": "Transaction and balance management endpoints",
      "endpoints": [
        {
          "id": 8,
          "name": "Get Account Balance",
          "method": "GET",
          "endpoint": "/transaction/balance/:accountId",
          "fullUrl": "http://localhost:5000/api/transaction/balance/65f8c2b3b3d4e5f6g7h8i9j1",
          "protected": true,
          "description": "Get current balance of a specific account",
          "urlParameters": {
            "accountId": "Account ID (required)"
          },
          "requestHeaders": {
            "Authorization": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "responseSuccess": {
            "statusCode": 200,
            "body": {
              "account": {
                "_id": "65f8c2b3b3d4e5f6g7h8i9j1",
                "accountNumber": "65f8c2b3b3d4e5f6g7h8i9j1",
                "balance": 50000,
                "currency": "INR",
                "status": "ACTIVE"
              },
              "message": "Balance fetched successfully"
            }
          },
          "notes": "User must own the account to view balance"
        },
        {
          "id": 9,
          "name": "System Initial Funds",
          "method": "POST",
          "endpoint": "/transaction/system/initial-funds",
          "fullUrl": "http://localhost:5000/api/transaction/system/initial-funds",
          "protected": true,
          "requiresSystemUser": true,
          "description": "Add initial funds to an account (System User Only)",
          "requestHeaders": {
            "Authorization": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "Content-Type": "application/json"
          },
          "requestBody": {
            "toAccount": "65f8c2b3b3d4e5f6g7h8i9j1",
            "amount": 50000,
            "idempotencyKey": "unique-key-12345"
          },
          "responseSuccess": {
            "statusCode": 201,
            "body": {
              "message": "Initial funds added successfully",
              "transaction": {
                "_id": "65f8c3c4c4e5f6g7h8i9j100",
                "fromAccount": "system-account-id",
                "toAccount": "65f8c2b3b3d4e5f6g7h8i9j1",
                "amount": 50000,
                "type": "INITIAL_FUND",
                "status": "COMPLETED",
                "idempotencyKey": "unique-key-12345",
                "createdAt": "2025-03-20T10:40:00.000Z"
              }
            }
          },
          "notes": "Only system users can add initial funds. Uses idempotency key to prevent duplicate transactions."
        }
      ]
    }
