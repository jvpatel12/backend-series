  "curlExamples": {
    "register": "curl -X POST http://localhost:5000/api/auth/register -H 'Content-Type: application/json' -d '{\"email\":\"john@example.com\",\"name\":\"John Doe\",\"password\":\"password123\"}'",
    "login": "curl -X POST http://localhost:5000/api/auth/login -H 'Content-Type: application/json' -d '{\"email\":\"john@example.com\",\"password\":\"password123\"}'",
    "getProfile": "curl -H 'Authorization: Bearer YOUR_TOKEN' http://localhost:5000/api/auth/user",
    "logout": "curl -X POST -H 'Authorization: Bearer YOUR_TOKEN' http://localhost:5000/api/auth/logout",
    "createAccount": "curl -X POST -H 'Authorization: Bearer YOUR_TOKEN' http://localhost:5000/api/account/create",
    "getAccountUser": "curl -H 'Authorization: Bearer YOUR_TOKEN' http://localhost:5000/api/account/user",
    "getAllAccounts": "curl -H 'Authorization: Bearer YOUR_TOKEN' http://localhost:5000/api/account/all",
    "getBalance": "curl -H 'Authorization: Bearer YOUR_TOKEN' http://localhost:5000/api/transaction/balance/ACCOUNT_ID",
    "initialFunds": "curl -X POST -H 'Authorization: Bearer SYSTEM_TOKEN' -H 'Content-Type: application/json' -d '{\"toAccount\":\"ACCOUNT_ID\",\"amount\":50000,\"idempotencyKey\":\"key123\"}' http://localhost:5000/api/transaction/system/initial-funds"
  },
